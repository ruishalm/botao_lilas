rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra: "cada um cuida do seu"
    // Permite que um usuário autenticado leia e escreva apenas
    // em documentos que pertençam ao seu próprio ID de usuário (uid).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Bloqueia todo o resto por padrão por segurança.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}